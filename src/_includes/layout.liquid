<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="author" content="Mark Brady">
    <meta name="generator" content="Eleventy">
    <title>{{ title }}</title>
    <meta name="description" content="{{ description }}">
    <meta property="og:title" content="{{ title }}">
    <meta property="og:description" content="{{ description }}">
    <meta property="og:type" content="{{ type | default: 'website' }}">
    <link rel="canonical" href="{{ site.url }}{{ page.url }}">
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="{{ title }}">
    <meta name="twitter:description" content="{{ description }}">
    <meta name="twitter:site" content="@inkyvoxel">
    <meta name="twitter:creator" content="@inkyvoxel">
    <meta name="theme-color" content="#000">
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#fff">
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>⬛</text></svg>"
    >
    <link rel="alternate" type="application/atom+xml" title="Feed" href="/feed.atom">
    <link rel="stylesheet" href="/assets/css/site.css">
    {% if content contains 'class="demo"' %}
      <link rel="stylesheet" href="/assets/css/demo.css">
    {% endif %}
  </head>

  <body>
    <header>
      <span class="voxel">
        <div class="face front"></div>
        <div class="face back"></div>
        <div class="face right"></div>
        <div class="face left"></div>
        <div class="face top"></div>
        <div class="face bottom"></div>
      </span>
      <nav>
        <ul>
          <li><a href="/">HOME</a></li>
          <li><a href="/about">ABOUT</a></li>
          <li><a href="/archives">ARCHIVES</a></li>
          <li><a href="/tags">TAGS</a></li>
        </ul>
      </nav>
    </header>

    <main>
      {{ content }}
    </main>

    <footer>
      <div class="support">
        <p>
          <a href="https://ko-fi.com/inkyvoxel" target="_blank" rel="noopener">Buy me a coffee… or some AI tokens</a>
          ☕
        </p>
      </div>
      <p>&copy; 2026 MARK BRADY. ALL RIGHTS RESERVED.</p>
    </footer>
  </body>
</html>
